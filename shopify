      margin-top: 12px;
      font-size: 14px;
      letter-spacing: 1px;
    }

    @media screen and (max-width: 1024px) {
      .category-grid__wrapper {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media screen and (max-width: 600px) {
      .category-grid__wrapper {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</section>

