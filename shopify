      content: "";
      display: block;
      width: 60px;
      height: 2px;
      background: #000;
      margin: 10px auto 0;
    }

    .category-grid__wrapper {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 40px 20px;
    }

    .category-grid__item {
